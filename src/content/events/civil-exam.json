        "text": "看看我这个专业怎么考公",
        "effects": [
          {
            "target": "skill",
            "value": 5,
            "label": "了解考公"
          }
        ],
        "nextEventId": "__civil_route_by_major__"
      }
    ],
    "noEncounters": true
